<?xml version="1.0" encoding="utf-8"?>
<!--
  shield_overlay.xml
  Layout for the block screen drawn on top of a blocked app.
  Inflated by AppBlockerService.drawOverlayShield().
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_lock_lock"
            android:contentDescription="Lock icon"
            android:alpha="0.85" />

        <TextView
            android:id="@+id/shield_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="Access Locked by Screentime Rules" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:gravity="center"
            android:text="Take a breath. You set this rule for a reason." />

        <Button
            android:id="@+id/shield_close_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:paddingHorizontal="32dp"
            android:paddingVertical="14dp"
            android:backgroundTint="#FFFFFFFF"
            android:textColor="#FF000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Close" />

    </LinearLayout>
</FrameLayout>
